generator client {
  provider      = "prisma-client-js"
  // Ship binaries for both glibc (Railway/Nixpacks) and musl (Dockerfile) runtimes
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                 String   @id @default(uuid())
  name               String
  logoDataUrl        String?
  backgroundColor    String?
  surfaceColor       String?
  cardColor          String?
  foregroundColor    String?
  mutedColor         String?
  accentColor        String?
  accentColor2       String?
  crmMode            String   @default("B2B")
  crmDisplayCurrency String   @default("USD")
  industry           String?
  contractSetup      Json?
  marketingSetup     Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  users                     User[]
  clients                   Client[]
  tasks                     Task[]
  invoices                  Invoice[]
  subscriptions             Subscription[]
  pipelines                 Pipeline[]
  stages                    Stage[]
  deals                     Deal[]
  dealStageHistory          DealStageHistory[]
  products                  Product[]
  dealItems                 DealItem[]
  userInvites               UserInvite[]
  googleCalendarConnections GoogleCalendarConnection[]
  clientCollaborators       ClientCollaborator[]
  projects                  Project[]
  projectSections           ProjectSection[]
  projectTasks              ProjectTask[]
  taskComments              TaskComment[]
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(MEMBER)
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant                   Tenant                    @relation(fields: [tenantId], references: [id])
  deals                    Deal[]                    @relation("DealOwner")
  googleCalendarConnection GoogleCalendarConnection?
  ownedProjects            Project[]                 @relation("ProjectOwner")
  assignedProjectTasks     ProjectTask[]             @relation("ProjectTaskAssignee")
  projectTaskComments      TaskComment[]             @relation("ProjectTaskCommentAuthor")
}

model Subscription {
  id               String             @id @default(uuid())
  tenantId         String
  customerTenantId String             @unique
  customerName     String
  contactFirstName String?
  contactLastName  String?
  contactEmail     String?
  plan             String             @default("TRIAL")
  seats            Int                @default(1)
  trialEndsAt      DateTime?
  status           SubscriptionStatus @default(ACTIVE)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model UserInvite {
  id               String       @id @default(uuid())
  tenantId         String
  email            String
  name             String?
  role             UserRole     @default(MEMBER)
  token            String       @unique
  status           InviteStatus @default(PENDING)
  invitedByUserId  String?
  acceptedByUserId String?
  acceptedAt       DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([tenantId, email])
}

model Client {
  id            String   @id @default(uuid())
  firstName     String?
  name          String
  function      String?
  companySector String?
  clientStatus  String   @default("CLIENT")
  dateOfBirth   String?
  email         String?
  phone         String?
  company       String?
  website       String?
  address       String?
  taxId         String?
  notes         String?
  tenantId      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant               @relation(fields: [tenantId], references: [id])
  tasks         Task[]
  invoices      Invoice[]
  deals         Deal[]
  collaborators ClientCollaborator[]
  projects      Project[]
  projectTasks  ProjectTask[]
}

model ClientCollaborator {
  id        String   @id @default(uuid())
  tenantId  String
  clientId  String
  firstName String?
  name      String
  function  String?
  email     String?
  whatsapp  String?
  comments  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([clientId])
  @@index([tenantId, clientId])
}

model Task {
  id             String     @id @default(uuid())
  title          String
  status         TaskStatus @default(PENDING)
  dueDate        DateTime?
  timeSpentHours Decimal?   @db.Decimal(8, 2)
  amount         Decimal?   @db.Decimal(12, 2)
  currency       String     @default("USD")
  tenantId       String
  clientId       String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  client Client @relation(fields: [clientId], references: [id])
}

model GoogleCalendarConnection {
  id                 String    @id @default(uuid())
  tenantId           String
  userId             String    @unique
  googleEmail        String
  refreshTokenCipher String
  calendarId         String    @default("primary")
  calendarSummary    String?
  lastSyncAt         DateTime?
  lastSyncError      String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Invoice {
  id           String        @id @default(uuid())
  tenantId     String
  clientId     String?
  amount       Decimal       @db.Decimal(10, 2)
  currency     String        @default("USD")
  status       InvoiceStatus @default(NEW)
  filePath     String
  issuedDate   DateTime?
  dueDate      DateTime?
  extractedRaw Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  client Client? @relation(fields: [clientId], references: [id])
}

model Pipeline {
  id        String   @id @default(uuid())
  name      String
  isDefault Boolean  @default(false)
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  stages Stage[]
  deals  Deal[]
}

model Stage {
  id          String      @id @default(uuid())
  name        String
  position    Int
  probability Float       @default(0)
  status      StageStatus @default(OPEN)
  tenantId    String
  pipelineId  String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant      Tenant             @relation(fields: [tenantId], references: [id])
  pipeline    Pipeline           @relation(fields: [pipelineId], references: [id])
  deals       Deal[]
  historyFrom DealStageHistory[] @relation("FromStage")
  historyTo   DealStageHistory[] @relation("ToStage")
}

model Deal {
  id                String    @id @default(uuid())
  title             String
  value             Decimal   @db.Decimal(12, 2)
  currency          String    @default("USD")
  probability       Float?
  expectedCloseDate DateTime?
  proposalFilePath  String?
  clientId          String?
  ownerId           String?
  tenantId          String
  pipelineId        String
  stageId           String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant   Tenant             @relation(fields: [tenantId], references: [id])
  client   Client?            @relation(fields: [clientId], references: [id], onDelete: SetNull)
  owner    User?              @relation("DealOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  pipeline Pipeline           @relation(fields: [pipelineId], references: [id])
  stage    Stage              @relation(fields: [stageId], references: [id])
  history  DealStageHistory[]
  items    DealItem[]
  projects Project[]

  @@index([ownerId])
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Decimal? @db.Decimal(12, 2)
  currency    String   @default("USD")
  isActive    Boolean  @default(true)
  tenantId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  dealItems DealItem[]

  @@index([tenantId])
}

model DealItem {
  id        String   @id @default(uuid())
  tenantId  String
  dealId    String
  productId String
  quantity  Int      @default(1)
  unitPrice Decimal? @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  deal    Deal    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([dealId, productId])
  @@index([tenantId])
  @@index([dealId])
  @@index([productId])
}

model DealStageHistory {
  id          String   @id @default(uuid())
  tenantId    String
  dealId      String
  fromStageId String?
  toStageId   String
  movedAt     DateTime @default(now())

  tenant    Tenant @relation(fields: [tenantId], references: [id])
  deal      Deal   @relation(fields: [dealId], references: [id])
  fromStage Stage? @relation("FromStage", fields: [fromStageId], references: [id])
  toStage   Stage  @relation("ToStage", fields: [toStageId], references: [id])
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
}

enum InvoiceStatus {
  NEW
  PROCESSING
  READY
}

enum StageStatus {
  OPEN
  WON
  LOST
}

enum ProjectStatus {
  DRAFT          @map("draft")
  ACTIVE         @map("active")
  WAITING_CLIENT @map("waiting_client")
  COMPLETED      @map("completed")
}

enum ProjectPriority {
  LOW    @map("low")
  MEDIUM @map("medium")
  HIGH   @map("high")
}

enum ProjectHealthStatus {
  HEALTHY  @map("healthy")
  RISK     @map("risk")
  CRITICAL @map("critical")
}

enum ProjectTaskStatus {
  TODO           @map("todo")
  IN_PROGRESS    @map("in_progress")
  WAITING_CLIENT @map("waiting_client")
  DONE           @map("done")
}

enum ProjectTaskPriority {
  LOW    @map("low")
  MEDIUM @map("medium")
  HIGH   @map("high")
}

model Project {
  id           String              @id @default(uuid())
  tenantId     String              @map("tenant_id")
  clientId     String              @map("client_id")
  dealId       String?             @map("deal_id")
  name         String
  description  String?
  status       ProjectStatus       @default(DRAFT)
  priority     ProjectPriority     @default(MEDIUM)
  healthStatus ProjectHealthStatus @default(HEALTHY) @map("health_status")
  ownerUserId  String?             @map("owner_user_id")
  startDate    DateTime?           @map("start_date")
  dueDate      DateTime?           @map("due_date")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client   Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  deal     Deal?            @relation(fields: [dealId], references: [id], onDelete: SetNull)
  owner    User?            @relation("ProjectOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  sections ProjectSection[]
  tasks    ProjectTask[]

  @@index([tenantId])
  @@index([clientId])
  @@index([dealId])
  @@index([ownerUserId])
  @@map("projects")
}

model ProjectSection {
  id        String @id @default(uuid())
  tenantId  String @map("tenant_id")
  projectId String @map("project_id")
  name      String
  position  Int

  tenant  Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   ProjectTask[]

  @@unique([projectId, position])
  @@index([tenantId])
  @@index([projectId])
  @@map("project_sections")
}

model ProjectTask {
  id             String              @id @default(uuid())
  tenantId       String              @map("tenant_id")
  projectId      String              @map("project_id")
  sectionId      String?             @map("section_id")
  clientId       String?             @map("client_id")
  title          String
  description    String?
  status         ProjectTaskStatus   @default(TODO)
  priority       ProjectTaskPriority @default(MEDIUM)
  assigneeUserId String?             @map("assignee_user_id")
  startDate      DateTime?           @map("start_date")
  dueDate        DateTime?           @map("due_date")
  estimatedHours Decimal?            @map("estimated_hours") @db.Decimal(8, 2)
  spentHours     Decimal?            @map("spent_hours") @db.Decimal(8, 2)
  parentTaskId   String?             @map("parent_task_id")
  position       Int                 @default(0)
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project  Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  section  ProjectSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  client   Client?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  assignee User?           @relation("ProjectTaskAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  parent   ProjectTask?    @relation("ProjectTaskParent", fields: [parentTaskId], references: [id], onDelete: SetNull)
  children ProjectTask[]   @relation("ProjectTaskParent")
  comments TaskComment[]

  @@index([tenantId])
  @@index([projectId])
  @@index([sectionId])
  @@index([clientId])
  @@index([assigneeUserId])
  @@index([parentTaskId])
  @@index([projectId, sectionId, position])
  @@map("project_tasks")
}

model TaskComment {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  taskId       String   @map("task_id")
  authorUserId String?  @map("author_user_id")
  body         String
  createdAt    DateTime @default(now()) @map("created_at")

  tenant Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  task   ProjectTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User?       @relation("ProjectTaskCommentAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([taskId])
  @@index([authorUserId])
  @@map("task_comments")
}
